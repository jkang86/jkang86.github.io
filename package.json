{
  "name": "joseph-kang-portfolio",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Joseph Kang portfolio — T1 esports editorial aesthetic. React 18 + Vite + TS + Tailwind + Framer Motion + GSAP + Lenis + Recharts.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
